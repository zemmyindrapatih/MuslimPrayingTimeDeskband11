<Window x:Class="PrayingTime.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="PrayingTime"
        SizeToContent="Width"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        Loaded="Window_Loaded"
        MouseRightButtonDown="Window_MouseRightButtonDown">

    <Window.Resources>
        <Storyboard x:Key="PulseStoryboard" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="CountdownText"
                             Storyboard.TargetProperty="Opacity"
                             From="1.0" To="0.4" Duration="0:0:0.8"
                             AutoReverse="True"/>
        </Storyboard>
        <Storyboard x:Key="FlashStoryboard">
            <ColorAnimation Storyboard.TargetName="MainBorder"
                            Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                            From="#FFDD88" To="#33C9A84B" Duration="0:0:1.5"/>
        </Storyboard>
        <DropShadowEffect x:Key="FloatingGlow" Color="#C9A84B" BlurRadius="14" ShadowDepth="0" Opacity="0.6"/>
    </Window.Resources>

    <!-- Outer container — #01000000 makes transparent areas hit-testable for mouse events -->
    <Grid x:Name="OuterGrid"
          Background="#01000000"
          MouseLeftButtonDown="OuterGrid_MouseLeftButtonDown"
          MouseMove="OuterGrid_MouseMove"
          MouseLeftButtonUp="OuterGrid_MouseLeftButtonUp">

        <Border x:Name="MainBorder"
                Background="Transparent"
                BorderThickness="0"
                CornerRadius="0"
                Padding="2,0">

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Main content row -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="32"/>   <!-- Icon -->
                        <ColumnDefinition Width="Auto"/> <!-- Previous prayer -->
                        <ColumnDefinition Width="50"/>   <!-- Progress bar -->
                        <ColumnDefinition Width="Auto"/> <!-- Next prayer (right) -->
                    </Grid.ColumnDefinitions>

                    <!-- Prayer icon (reflects current prayer type) -->
                    <TextBlock x:Name="PrayerIcon"
                               Grid.Column="0"
                               Text="☽"
                               FontFamily="Segoe UI Symbol"
                               FontSize="20"
                               Foreground="{StaticResource GoldBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               Margin="2,0,2,2">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#C9A84B" BlurRadius="6" ShadowDepth="0" Opacity="0.7"/>
                        </TextBlock.Effect>
                    </TextBlock>

                    <!-- Previous prayer: name + elapsed time -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" HorizontalAlignment="Left">
                        <TextBlock x:Name="PrevPrayerNameText"
                                   Text="Fajr"
                                   FontFamily="Segoe UI Variable Display"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Foreground="{StaticResource IvoryBrush}"
                                   Margin="2,2,6,0"/>
                        <TextBlock x:Name="ElapsedText"
                                   Text="--:--"
                                   FontFamily="Segoe UI Variable Display"
                                   FontWeight="SemiBold"
                                   FontSize="20"
                                   Foreground="{StaticResource AmberBrush}"
                                   Margin="2,0,6,2">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#E8A020" BlurRadius="4" ShadowDepth="0" Opacity="0.5"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </StackPanel>

                    <!-- Progress bar column -->
                    <Grid Grid.Column="2" VerticalAlignment="Center" Margin="4,0">
                        <Rectangle Height="4" RadiusX="2" RadiusY="2" Fill="#55C9A84B"/>
                        <Rectangle x:Name="ProgressBar"
                                   Height="4" RadiusX="2" RadiusY="2"
                                   HorizontalAlignment="Left">
                            <Rectangle.Fill>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#C9A84B" Offset="0"/>
                                    <GradientStop Color="#FFDD88" Offset="1"/>
                                </LinearGradientBrush>
                            </Rectangle.Fill>
                        </Rectangle>
                    </Grid>

                    <!-- Next prayer: name + countdown -->
                    <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right">
                        <TextBlock x:Name="PrayerNameText"
                                   Text="Maghrib"
                                   FontFamily="Segoe UI Variable Display"
                                   FontWeight="SemiBold"
                                   FontSize="14"
                                   Foreground="{StaticResource IvoryBrush}"
                                   HorizontalAlignment="Right"
                                   Margin="6,2,2,0"/>
                        <TextBlock x:Name="CountdownText"
                                   Text="--:--"
                                   FontFamily="Segoe UI Variable Display"
                                   FontWeight="SemiBold"
                                   FontSize="20"
                                   Foreground="{StaticResource IvoryBrush}"
                                   HorizontalAlignment="Right"
                                   Margin="6,0,2,2">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="#E8A020" BlurRadius="4" ShadowDepth="0" Opacity="0.5"/>
                            </TextBlock.Effect>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- Context menu -->
        <Grid.ContextMenu>
            <ContextMenu Background="#0D1117" BorderBrush="#33C9A84B">
                <MenuItem x:Name="MenuAbout" Click="MenuAbout_Click">
                    <MenuItem.Icon>
                        <TextBlock Text="&#xE946;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#C9A84B" VerticalAlignment="Center"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem x:Name="MenuLocation" Header="Location Settings" Click="MenuLocation_Click">
                    <MenuItem.Icon>
                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#C9A84B" VerticalAlignment="Center"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem x:Name="MenuRefresh" Header="Refresh Prayer Times" Click="MenuRefresh_Click">
                    <MenuItem.Icon>
                        <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#C9A84B" VerticalAlignment="Center"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem x:Name="MenuDock" Header="Snap to SysTray" Click="MenuDock_Click">
                    <MenuItem.Icon>
                        <TextBlock Text="&#xE718;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#C9A84B" VerticalAlignment="Center"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="MenuLock" Header="Lock Position" Click="MenuLock_Click">
                    <MenuItem.Icon>
                        <TextBlock Text="&#xE72E;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#C9A84B" VerticalAlignment="Center"/>
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem x:Name="MenuStartup" Header="Run at Windows Startup" Click="MenuStartup_Click">
                    <MenuItem.Icon>
                        <TextBlock Text="&#xEC60;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#888888" VerticalAlignment="Center"/>
                    </MenuItem.Icon>
                </MenuItem>
                <Separator/>
                <MenuItem x:Name="MenuExit" Header="Exit" Click="MenuExit_Click">
                    <MenuItem.Icon>
                        <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="13" Foreground="#C9A84B" VerticalAlignment="Center"/>
                    </MenuItem.Icon>
                </MenuItem>
            </ContextMenu>
        </Grid.ContextMenu>
    </Grid>
</Window>
